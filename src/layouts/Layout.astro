---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const { 
  title, 
  description = "Professional signage and print design services for businesses, events, and personal projects. Custom designs delivered with quality.",
  image = "/images/og-image.jpg",
  canonicalURL = Astro.url.pathname
} = Astro.props;

const siteTitle = "Lumina Design Studio";
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary Meta Tags -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Lumina Design Studio" />
  
  <!-- Canonical URL -->
  <link rel="canonical" href={`https://your-studio.github.io${canonicalURL}`} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://your-studio.github.io${canonicalURL}`} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://your-studio.github.io${image}`} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={`https://your-studio.github.io${canonicalURL}`} />
  <meta property="twitter:title" content={fullTitle} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={`https://your-studio.github.io${image}`} />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Structured Data -->
  <script type="application/ld+json">
    {{
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Lumina Design Studio",
      "description": "Professional signage and print design services",
      "url": "https://your-studio.github.io",
      "image": "https://your-studio.github.io/images/logo.png",
      "priceRange": "$$",
      "serviceType": ["Signage Design", "Print Design", "Banner Design", "Custom Stickers"]
    }}
  </script>
  
  <style>
    /* Critical CSS for above-the-fold content */
    body { margin: 0; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
